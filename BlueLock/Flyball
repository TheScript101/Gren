local function toggle()
    enabled = not enabled

    if enabled then
        button.Text = "ON"
        button.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        enableMove()
    else
        button.Text = "OFF"
        button.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        disableMove()
    end
end


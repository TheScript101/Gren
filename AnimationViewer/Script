-- Confirm handler (attempt to pause animation at exact keyframe)
confirmBtn.MouseButton1Click:Connect(function()
    local seq = kfFrame.SelectedSequence
    local keyframes = kfFrame.KeyframesList or {}
    if not seq then
        toast("No sequence selected.")
        return
    end
    local n = toPositiveInteger(numberBox.Text)
    if not n or n < 1 or n > #keyframes then
        toast("Enter a valid keyframe number between 1 and " .. tostring(#keyframes))
        return
    end
    local kf = keyframes[n]
    if not kf then
        toast("Keyframe not found.")
        return
    end
    local targetTime = kf.Time or 0
    -- Try to find an Animation asset associated with this KeyframeSequence / model
    local animInstance = findAssociatedAnimation(selectedModel, seq)
    if not animInstance then
        toast("No Animation asset found to play this sequence. Can't freeze the Animator.")
        return
    end
    local humanoid = selectedModel:FindFirstChildOfClass("Humanoid")
    if not humanoid then
        toast("Selected model has no Humanoid (unexpected).")
        return
    end
    -- Ensure Animator exists
    local animator = humanoid:FindFirstChild("Animator")
    if not animator then
        -- In some cases, animations are played via AnimationController. Try to create Animator.
        animator = Instance.new("Animator")
        animator.Parent = humanoid
    end

    -- Prepare Animation object to load, ensure it has AnimationId set
    local animationToLoad = animInstance
    if not animationToLoad.AnimationId or animationToLoad.AnimationId == "" then
        toast("Found Animation object but it has no AnimationId. Can't play.")
        return
    end

    -- Load and play
    local success, trackOrErr = pcall(function()
        local track = animator:LoadAnimation(animationToLoad)
        track:Play()
        track:AdjustSpeed(1)
        return track
    end)
    if not success or not trackOrErr then
        toast("Failed to load/play animation: " .. tostring(trackOrErr))
        return
    end
    local track = trackOrErr
    -- Wait until the track has a TimePosition property updating
    local timeout = 5
    local elapsed = 0
    while elapsed < timeout and (not track.IsPlaying) do
        wait(0.05)
        elapsed = elapsed + 0.05
    end

    -- Freeze at targetTime
    -- clamp the time inside track length if possible
    local ok, len = pcall(function() return track.Length end)
    if ok and len and len > 0 then
        if targetTime > len then
            targetTime = len
        end
    end

    -- Use RenderStepped to set TimePosition and pause (frame-exact)
    local conn
    conn = RunService.RenderStepped:Connect(function()
        if track.TimePosition >= targetTime then
            track.TimePosition = targetTime
            track:AdjustSpeed(0) -- freeze
            conn:Disconnect()
            toast("Frozen at keyframe #"..tostring(n).." (time: "..tostring(targetTime).. "s).")
        end
    end)
end)


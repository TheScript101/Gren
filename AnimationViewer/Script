-- === Helper functions =======================================================
local function isHumanoidModel(model)
    if not model or not model:IsA("Model") then return false end
    return model:FindFirstChildOfClass("Humanoid") ~= nil
end

local function findKeyframeSequences(model)
    local seqs = {}
    for _, v in ipairs(model:GetDescendants()) do
        if v:IsA("KeyframeSequence") then
            table.insert(seqs, v)
        end
    end
    table.sort(seqs, function(a,b) return tostring(a.Name) < tostring(b.Name) end)
    return seqs
end

-- Try to find an Animation instance associated with the KeyframeSequence
local function findAssociatedAnimation(model, keyframeSequence)
    -- 1) Look for Animation instances in model descendants whose Name matches KFS name
    for _, a in ipairs(model:GetDescendants()) do
        if a:IsA("Animation") then
            if a.Name == keyframeSequence.Name then return a end
        end
    end
    -- 2) Look for Animation instance that contains the KeyframeSequence as descendant (rare but possible)
    for _, a in ipairs(model:GetDescendants()) do
        if a:IsA("Animation") then
            for _, d in ipairs(a:GetDescendants()) do
                if d == keyframeSequence then return a end
            end
        end
    end
    -- 3) Search ReplicatedStorage for Animation with same name (useful if dev stored animations there)
    for _, a in ipairs(ReplicatedStorage:GetDescendants()) do
        if a:IsA("Animation") and a.Name == keyframeSequence.Name then
            return a
        end
    end
    -- 4) Try any Animation in the model (fallback to first found)
    for _, a in ipairs(model:GetDescendants()) do
        if a:IsA("Animation") then return a end
    end
    return nil
end

-- Create a Highlight around a model (returns the Highlight instance)
local function createHighlightForModel(model)
    -- remove any existing highlight we previously created
    for _,child in ipairs(model:GetChildren()) do
        if child:IsA("Highlight") and child.Name == "__SelectHighlight" then
            child:Destroy()
        end
    end
    local highlight = Instance.new("Highlight")
    highlight.Name = "__SelectHighlight"
    highlight.Parent = model
    highlight.FillTransparency = 1 -- no fill, outline only
    highlight.OutlineColor = Color3.fromRGB(0, 170, 255) -- blueish
    highlight.OutlineTransparency = 0
    return highlight
end

-- Utility: clear highlight if present
local function clearHighlight(model)
    if not model then return end
    local h = model:FindFirstChild("__SelectHighlight")
    if h and h:IsA("Highlight") then h:Destroy() end
end

-- Safely parse number
local function toPositiveInteger(str)
    local n = tonumber(str)
    if not n then return nil end
    n = math.floor(n)
    if n < 1 then return nil end
    return n
end


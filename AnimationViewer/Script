-- === Selection logic ======================================================
local function onHover(target)
    -- highlight for hover (but only for humanoids)
    if target and target.Parent then
        local m = target:FindFirstAncestorOfClass("Model")
        if isHumanoidModel(m) then
            -- temporary highlight via Outline using Selection? we will not show hover highlight separate from selected
            hoveredModel = m
            return
        end
    end
    hoveredModel = nil
end

local function enableSelectionMode(enable)
    selectionEnabled = enable
    if selectionEnabled then
        toggleBtn.Text = "Disable Selection"
        toast("Selection enabled: click a humanoid model to pick it.")
    else
        toggleBtn.Text = "Enable Selection"
        hoveredModel = nil
    end
end

-- Mouse / Input handling for selection
mouse.Move:Connect(function()
    if not selectionEnabled then return end
    local target = mouse.Target
    onHover(target)
end)

-- Click to pick
local clickConn
clickConn = mouse.Button1Down:Connect(function()
    if not selectionEnabled then return end
    local target = mouse.Target
    if not target then return end
    local model = target:FindFirstAncestorOfClass("Model")
    if isHumanoidModel(model) then
        -- mark selected
        if selectedModel and selectedModel ~= model then
            clearHighlight(selectedModel)
        end
        selectedModel = model
        selectedLabel.Text = "Selected: " .. (selectedModel.Name or "(unnamed)")
        highlightInstance = createHighlightForModel(selectedModel)
    else
        toast("That is not a humanoid model. Click a model containing a Humanoid.")
    end
end)


-- Select button: opens KeyframeSequence browser for the selected humanoid
-- Replace the whole selectBtn.MouseButton1Click handler with this block

selectBtn.MouseButton1Click:Connect(function()
    if not selectedModel then
        toast("No humanoid selected.")
        return
    end
    -- verify still has Humanoid
    if not isHumanoidModel(selectedModel) then
        toast("Selected target no longer a humanoid model.")
        return
    end

    -- Clear previous list (remove TextButtons and TextLabels we created previously)
    for _, child in ipairs(seqScroll:GetChildren()) do
        if child:IsA("TextButton") or child:IsA("TextLabel") then
            child:Destroy()
        end
    end

    local seqs = findKeyframeSequences(selectedModel)
    if #seqs == 0 then
        local noneLabel = Instance.new("TextLabel", seqScroll)
        noneLabel.Size = UDim2.new(1, 0, 0, 30)
        noneLabel.Text = "No key frame sequence found."
        noneLabel.BackgroundTransparency = 1
        noneLabel.TextColor3 = Color3.new(1,1,1)
        noneLabel.Font = Enum.Font.Gotham
        noneLabel.TextSize = 16
        -- ensure scroll area updates
        seqScroll.CanvasSize = UDim2.new(0,0,0,40)
    else
        local createdButtons = 0
        for i, seq in ipairs(seqs) do
            local thisSeq = seq -- capture local copy to avoid closure bug

            -- count keyframes inside this sequence
            local keyframes = {}
            for _, kf in ipairs(thisSeq:GetChildren()) do
                if kf:IsA("Keyframe") then
                    table.insert(keyframes, kf)
                end
            end

            local btn = Instance.new("TextButton", seqScroll)
            btn.Size = UDim2.new(1, 0, 0, 34)
            btn.Position = UDim2.new(0, 0, 0, 0)
            btn.Text = tostring(thisSeq.Name) .. "  (" .. tostring(#keyframes) .. " keyframes)"
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 16
            btn.BackgroundColor3 = Color3.fromRGB(50,50,50)
            btn.TextColor3 = Color3.new(1,1,1)
            btn.Name = "KFSeqBtn_" .. i

            -- capture local keyframes list for this button as well
            local localKeyframes = keyframes
            table.sort(localKeyframes, function(a,b) return a.Time < b.Time end)

            btn.MouseButton1Click:Connect(function()
                -- open keyframe detail screen for this seq
                kfHeader.Text = "Keyframes: " .. tostring(#localKeyframes)
                -- store direct references for confirm handler
                kfFrame.SelectedSequence = thisSeq
                kfFrame.KeyframesList = localKeyframes
                -- clear any previously entered number
                numberBox.Text = ""
                infoLabel.Text = ""
                -- switch frames
                mainFrame.Visible = false
                seqFrame.Visible = false
                kfFrame.Visible = true
            end)

            createdButtons = createdButtons + 1
        end

        -- update canvas size manually so scrolling works reliably
        local totalHeight = createdButtons * 40 + 6
        seqScroll.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
    end

    -- Show seqFrame
    mainFrame.Visible = false
    seqFrame.Visible = true
end)

